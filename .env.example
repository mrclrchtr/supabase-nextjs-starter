# Local development should point at your local Supabase stack by default.
# Run `supabase status -o env` after `supabase start` and copy the local values here.
# Remote staging/project API values belong in hosted deployment env configuration, not normal local development.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-local-publishable-key
