{
	"name": "supabase-nextjs-starter",
	"description": "A production ready Next.js/Supabase starter. ",
	"version": "0.0.1",
	"private": true,
	"author": "Marcel Richter",
	"license": "MIT",
	"keywords": [
		"nextjs",
		"starter",
		"supabase",
		"tailwindcss",
		"shadcn",
		"typescript",
		"biome"
	],
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"biome": "biome check",
		"biome:fix": "biome check --write",
		"biome:ci": "biome ci",
		"typecheck": "tsc --pretty --noEmit",
		"test": "vitest",
		"test:ci": "vitest run",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"test:e2e:ci": "playwright test --reporter=line",
		"knip": "knip --dependencies",
		"check": "pnpm biome:ci && pnpm typecheck && pnpm knip && pnpm test:ci",
		"check:fix": "pnpm biome:fix && pnpm check",
		"analyze": "ANALYZE=true pnpm build"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.0",
		"@supabase/supabase-js": "^2.89.0",
		"@tanstack/react-query": "^5.90.12",
		"@tanstack/react-query-devtools": "^5.91.1",
		"@vercel/analytics": "^1.6.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.577.0",
		"next": "16.2.10",
		"next-themes": "^0.4.6",
		"nextjs-toploader": "^3.9.17",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"shadcn": "^4.0.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@tailwindcss/postcss": "4.2.2",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/node": "25.9.5",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@playwright/test": "1.61.1",
		"@vitejs/plugin-react": "5.2.0",
		"@vitest/ui": "4.1.10",
		"axios": "1.18.1",
		"jsdom": "28.1.0",
		"knip": "5.88.1",
		"msw": "2.15.0",
		"postcss": "8.5.16",
		"tailwindcss": "4.2.2",
		"typescript": "5.9.3",
		"vitest": "4.1.10"
	},
	"packageManager": "pnpm@10.34.4"
}
